debug_output.log

# Internal maintainer docs (not for public repo)
.internal/

# Local project config
decibench.toml

# Test + coverage artifacts
.coverage
htmlcov/

# Guard against re-introducing the dev-side scenarios duplicate. The canonical
# home is src/decibench/scenarios/suites/ and tests/test_scenarios_canonical.py
# fails if anything reappears here.
/scenarios/
